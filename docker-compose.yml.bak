services:

  app:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: abaad-app
    ports:
      - "8080:80"
    environment:
      APP_NAME: AbaadApp
      APP_ENV: local
      APP_KEY: base64:MEwXt2DGlFhNN2I/gUQM6Oq4o/PKvfh38irbiplDDvk=
      APP_DEBUG: "true"
      APP_URL: http://localhost:8080

      DB_CONNECTION: mysql
      DB_HOST: host.docker.internal
      DB_PORT: "3306"
      DB_DATABASE: abaadapp_abaad_pdm
      DB_USERNAME: root
      DB_PASSWORD: ""

      CACHE_DRIVER: redis
      QUEUE_CONNECTION: redis
      SESSION_DRIVER: redis
      REDIS_HOST: redis
      REDIS_PORT: "6379"

    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - abaad-net
    volumes:
      - storage_data:/var/www/html/storage/app

  db:
    image: mysql:8.0
    container_name: abaad-db
    environment:
      MYSQL_DATABASE: abaad_db
      MYSQL_USER: abaad_user
      MYSQL_PASSWORD: secret123
      MYSQL_ROOT_PASSWORD: rootsecret
    volumes:
      - db_data:/var/lib/mysql
    ports:
      - "3307:3306"
    networks:
      - abaad-net
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-prootsecret"]
      interval: 10s
      timeout: 5s
      retries: 5

  redis:
    image: redis:7-alpine
    container_name: abaad-redis
    ports:
      - "6380:6379"
    networks:
      - abaad-net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3

  phpmyadmin:
    image: phpmyadmin:latest
    container_name: abaad-phpmyadmin
    environment:
      PMA_HOST: db
      PMA_PORT: "3306"
      PMA_USER: root
      PMA_PASSWORD: rootsecret
      UPLOAD_LIMIT: 300M
    ports:
      - "8081:80"
    depends_on:
      db:
        condition: service_healthy
    networks:
      - abaad-net

volumes:
  db_data:
  storage_data:

networks:
  abaad-net:
    driver: bridge
