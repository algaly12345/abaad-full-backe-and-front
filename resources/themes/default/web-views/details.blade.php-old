@push('script')
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyAFuZIjGVfo57sJk3EmCSV0SpP7qVgg7n4&libraries=places&callback=initMap" async defer></script>

<script>
    const estateImages = @json(is_array($estate['images'] ?? null) ? $estate['images'] : []);
    const estatePlans  = @json(is_array($estate['planned'] ?? null) ? $estate['planned'] : []);

    document.addEventListener('DOMContentLoaded', function () {
        initMediaTabs();
        initImageGallery();
        initPlanGallery();
        initVideoSelector();
    });

    function initMediaTabs(){
        const tabs = document.querySelectorAll('.media-tab');
        const panels = document.querySelectorAll('.media-panel');

        tabs.forEach(tab => {
            tab.addEventListener('click', function(){
                const target = this.dataset.mediaTab;

                tabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');

                panels.forEach(panel => {
                    panel.classList.toggle('d-none', panel.dataset.panel !== target);
                });
            });
        });
    }

    function switchMediaTab(tabName){
        const tab = document.querySelector(`.media-tab[data-media-tab="${tabName}"]`);
        if(tab) tab.click();
    }

    function initImageGallery(){
        const railItems = document.querySelectorAll('#imageRail .rail-item');
        const mainImage = document.getElementById('mainGalleryImage');
        const currentIndex = document.getElementById('imageCurrentIndex');

        if(!railItems.length || !mainImage) return;

        railItems.forEach(item => {
            item.addEventListener('click', function(){
                railItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');

                mainImage.src = this.dataset.src;
                if(currentIndex) currentIndex.textContent = parseInt(this.dataset.index, 10) + 1;
            });
        });
    }

    function initPlanGallery(){
        const railItems = document.querySelectorAll('#planRail .rail-item');
        const mainImage = document.getElementById('mainPlanImage');

        if(!railItems.length || !mainImage) return;

        railItems.forEach(item => {
            item.addEventListener('click', function(){
                railItems.forEach(i => i.classList.remove('active'));
                this.classList.add('active');
                mainImage.src = this.dataset.src;
            });
        });
    }

    function initVideoSelector(){
        const selectors = document.querySelectorAll('.video-selector');
        const mainSource = document.getElementById('mainVideoSource');
        const mainPlayer = document.getElementById('mainVideoPlayer');
        const title = document.getElementById('videoTitleOverlay');

        if(!selectors.length || !mainSource || !mainPlayer) return;

        selectors.forEach(btn => {
            btn.addEventListener('click', function(){
                selectors.forEach(s => s.classList.remove('active'));
                this.classList.add('active');

                mainSource.src = this.dataset.videoSrc;
                if(title) title.textContent = this.dataset.videoTitle || 'فيديو';
                mainPlayer.load();
                mainPlayer.play().catch(() => {});
            });
        });
    }

    function openMediaGallery(type){
        const body = document.getElementById('mediaGalleryModalBody');
        let html = '';

        if(type === 'images'){
            if(!estateImages.length){
                html = '<div class="text-center text-muted">لا توجد صور</div>';
            }else{
                html = '<div class="fullscreen-gallery">';
                estateImages.forEach(img => {
                    html += `
                        <img src="{{ asset('storage/app/public/estate') }}/${img}"
                             onerror="this.src='{{ asset('storage/app/public/estate/not_found.png') }}'"
                             alt="gallery image">`;
                });
                html += '</div>';
            }
        }

        body.innerHTML = html;
        new bootstrap.Modal(document.getElementById('mediaGalleryModal')).show();
    }

    function loadStreetViewInline(){
        const lat = Number("{{ $estate['latitude'] ?? 0 }}");
        const lon = Number("{{ $estate['longitude'] ?? 0 }}");
        const panel = document.getElementById('streetViewPanel');

        if (!isNaN(lat) && !isNaN(lon) && lat !== 0 && lon !== 0) {
            const apiKey = "AIzaSyAFuZIjGVfo57sJk3EmCSV0SpP7qVgg7n4";
            const streetViewUrl = `https://www.google.com/maps/embed/v1/streetview?key=${apiKey}&location=${lat},${lon}&heading=210&pitch=10&fov=35`;

            panel.innerHTML = `
                <iframe
                    width="100%"
                    height="100%"
                    style="border:0;"
                    src="${streetViewUrl}"
                    allowfullscreen
                    loading="lazy"></iframe>
                <div class="preview-overlay">
                    <div class="title">منظور الشارع</div>
                    <div class="meta">استكشاف محيط العقار بشكل مباشر</div>
                </div>
            `;

            const container = document.getElementById('street-view-container');
            if(container){
                container.innerHTML = `
                    <iframe
                        width="100%"
                        height="580"
                        style="border:0;display:block;"
                        src="${streetViewUrl}"
                        allowfullscreen
                        loading="lazy"></iframe>
                `;
            }
        } else {
            panel.innerHTML = `
                <div class="empty-media" style="min-height:560px;">
                    <i class="fa-solid fa-triangle-exclamation fa-2x"></i>
                    <div>تعذر عرض منظور الشارع - الإحداثيات غير صالحة</div>
                </div>
            `;
        }
    }

    function setNearbyActive(button){
        document.querySelectorAll('.nearby-btn').forEach(btn => btn.classList.remove('active'));
        button.classList.add('active');
    }

    document.getElementById("reportForm")?.addEventListener("submit", function(event) {
        event.preventDefault();

        let formData = new FormData(this);

        fetch("{{ route('report') }}", {
            method: "POST",
            headers: {
                "X-CSRF-TOKEN": "{{ csrf_token() }}",
                "Accept": "application/json"
            },
            body: formData
        })
        .then(response => {
            if (!response.ok) {
                return response.text().then(text => { throw new Error(text); });
            }
            return response.json();
        })
        .then(() => {
            bootstrap.Modal.getInstance(document.getElementById('reportModal'))?.hide();
            new bootstrap.Modal(document.getElementById('successModal')).show();
            document.getElementById("reportForm").reset();
        })
        .catch(error => console.error("Error:", error));
    });

    let map, service, infowindow, currentLocationMarker, userLocation;
    window.placeMarkers = [];

    function initMap() {
        userLocation = new google.maps.LatLng({{ $estate['latitude'] ?? 24.7136 }}, {{ $estate['longitude'] ?? 46.6753 }});

        map = new google.maps.Map(document.getElementById('map'), {
            center: userLocation,
            zoom: 15,
            mapTypeControl: false,
            streetViewControl: false,
            fullscreenControl: true
        });

        currentLocationMarker = new google.maps.Marker({
            position: userLocation,
            map: map,
            title: "موقع العقار",
            icon: { url: "http://maps.google.com/mapfiles/ms/icons/blue-dot.png" }
        });

        infowindow = new google.maps.InfoWindow();
    }

    function searchNearby(type) {
        if (!userLocation || !map) return;

        const request = {
            location: userLocation,
            radius: 5000,
            type: type
        };

        service = new google.maps.places.PlacesService(map);
        service.nearbySearch(request, (results, status) => {
            if (status === google.maps.places.PlacesServiceStatus.OK) {
                if (window.placeMarkers.length) {
                    window.placeMarkers.forEach(marker => marker.setMap(null));
                }
                window.placeMarkers = [];
                results.forEach(place => createMarker(place));
            }
        });
    }

    function createMarker(place) {
        if (!place.geometry || !place.geometry.location) return;

        const types = place.types || [];
        let iconUrl = null;

        for (let i = 0; i < types.length; i++) {
            iconUrl = getIconForPlaceType(types[i]);
            if (iconUrl) break;
        }

        const marker = new google.maps.Marker({
            map,
            position: place.geometry.location,
            icon: iconUrl ? {
                url: iconUrl,
                scaledSize: new google.maps.Size(32, 50)
            } : undefined
        });

        window.placeMarkers.push(marker);

        google.maps.event.addListener(marker, 'click', () => {
            infowindow.setContent(place.name || "");
            infowindow.open(map, marker);
        });
    }

    function getIconForPlaceType(placeType) {
        const iconBase = "{{ asset('public/assets/images/') }}/";
        switch (placeType) {
            case 'school': return iconBase + 'mark_school.png';
            case 'pharmacy': return iconBase + 'mark_pharmcy.png';
            case 'hospital': return iconBase + 'mark_hosiptal.png';
            case 'restaurant': return iconBase + 'mark_restaurant.png';
            default: return null;
        }
    }
</script>


<script>
 $(document).ready(function () {
    // جلب القيم من السيرفر
    let adLicenseNumber = "{{ $estate['ad_number'] ?? '' }}";
    let idType = "{{ $estate['estate_type'] ?? 0 }}";
    
     
    let identity = "{{ $estate['identityـorـunified'] ?? 0 }}";

    // تحديد قيمة advertiserId حسب نوع idType
    let advertiserId = "";
    if (idType == 1) {
        // فرد
        advertiserId = "{{ $agent['identity'] ?? '' }}";
    } else if (idType == 2) {
        // مؤسسة / شركة
        advertiserId = "{{ $agent['unified_number'] ?? '' }}";
    }

    console.log("adLicenseNumber:", adLicenseNumber);
    console.log("idType:", idType);
    console.log("advertiserId:", identity);

    // إرسال الطلب للسيرفر
    $.ajax({
        url: "https://app.abaadapp.sa/api/v1/banners/advertisement/validate",
        type: "POST",
        data: {
            adLicenseNumber: adLicenseNumber,
            advertiserId: identity,
            idType: idType
        },

        success: function (response) {
            if (response.success === false || response.message === "رقم إعلان غير صحيح") {
                showFullScreenMessage("الإعلان غير صالح أو منتهي");
            }
        },

        error: function (xhr) {
            if (xhr.responseJSON && xhr.responseJSON.message === "رقم إعلان غير صحيح") {
                showFullScreenMessage("الإعلان غير صالح أو منتهي");
            } else if (xhr.responseJSON && xhr.responseJSON.message) {
                showFullScreenMessage(xhr.responseJSON.message);
            } else {
                showFullScreenMessage("حدث خطأ غير متوقع");
            }
        }
    });

    // دالة عرض رسالة شاشة كاملة
    function showFullScreenMessage(msg) {
        // اخفاء كل محتوى الصفحة
        $("body").children().hide();

        // إضافة شاشة كاملة بالرسالة
        $("body").append(`
            <div id="full-screen-error" style="
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                text-align: center;
                padding: 20px;
                z-index: 999999;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            ">
                <div style="
                    background-color: white;
                    border-radius: 20px;
                    padding: 40px;
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
                    max-width: 600px;
                    width: 90%;
                    animation: fadeIn 0.5s ease-in-out;
                ">
                    <div style="
                        color: #e74c3c;
                        font-size: 80px;
                        margin-bottom: 20px;
                    ">
                        ⚠️
                    </div>
                    <h2 style="
                        color: #2c3e50;
                        font-size: 28px;
                        margin-bottom: 15px;
                        font-weight: 600;
                    ">
                        تنبيه
                    </h2>
                    <p style="
                        color: #34495e;
                        font-size: 20px;
                        margin-bottom: 30px;
                        line-height: 1.5;
                    ">
                        ${msg}
                    </p>
                    <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
                        <button id="go-back-btn" style="
                            padding: 15px 30px;
                            font-size: 18px;
                            font-weight: 600;
                            background: #3498db;
                            color: white;
                            border: none;
                            border-radius: 50px;
                            cursor: pointer;
                            transition: all 0.3s ease;
                            box-shadow: 0 4px 10px rgba(52, 152, 219, 0.3);
                        ">
                            ⬅ الرجوع للشاشة السابقة
                        </button>
                        <button id="refresh-btn" style="
                            padding: 15px 30px;
                            font-size: 18px;
                            font-weight: 600;
                            background: #2ecc71;
                            color: white;
                            border: none;
                            border-radius: 50px;
                            cursor: pointer;
                            transition: all 0.3s ease;
                            box-shadow: 0 4px 10px rgba(46, 204, 113, 0.3);
                        ">
                            🔄 إعادة تحميل الصفحة
                        </button>
                    </div>
                </div>
            </div>
            
            <style>
                @keyframes fadeIn {
                    from { opacity: 0; transform: translateY(-20px); }
                    to { opacity: 1; transform: translateY(0); }
                }
                
                #go-back-btn:hover, #refresh-btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2);
                }
                
                @media (max-width: 768px) {
                    #full-screen-error div {
                        padding: 30px 20px;
                    }
                    
                    #full-screen-error h2 {
                        font-size: 24px;
                    }
                    
                    #full-screen-error p {
                        font-size: 18px;
                    }
                    
                    #go-back-btn, #refresh-btn {
                        font-size: 16px;
                        padding: 12px 20px;
                    }
                }
            </style>
        `);

        // زر الرجوع
        $("#go-back-btn").on("click", function () {
            $("#full-screen-error").remove();   // إزالة شاشة الخطأ
            history.back();                     // العودة للصفحة السابقة
        });
        
        // زر إعادة التحميل
        $("#refresh-btn").on("click", function () {
            location.reload();                  // إعادة تحميل الصفحة
        });
    }
});
</script>
@endpush