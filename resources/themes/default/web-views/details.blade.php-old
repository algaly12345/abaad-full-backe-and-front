@extends('layouts.front-end.app')

@section('title', $estate['title'])

@push('css_or_js')
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css" rel="stylesheet">

<style>
    :root{
        --bg: #0b1020;
        --surface: rgba(255,255,255,.08);
        --surface-2: rgba(255,255,255,.12);
        --card: #ffffff;
        --text: #101828;
        --muted: #667085;
        --line: #e4e7ec;
        --primary: #0f5bd7;
        --primary-2: #114b89;
        --accent: #19b36b;
        --danger: #ef4444;
        --warning: #f59e0b;
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --radius-sm: 12px;
        --shadow-lg: 0 24px 60px rgba(16,24,40,.18);
        --shadow-md: 0 12px 30px rgba(16,24,40,.10);
        --shadow-sm: 0 8px 20px rgba(16,24,40,.08);
    }

    body{
        background:
            radial-gradient(circle at top right, rgba(17,75,137,.15), transparent 25%),
            radial-gradient(circle at top left, rgba(15,91,215,.15), transparent 25%),
            #f4f7fb;
        color: var(--text);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .estate-shell{
        padding: 28px 0 90px;
    }

    .glass-hero{
        position: relative;
        overflow: hidden;
        border-radius: 32px;
        background:
            linear-gradient(135deg, rgba(10,16,32,.92), rgba(17,75,137,.85));
        box-shadow: var(--shadow-lg);
        color: #fff;
        padding: 24px;
        margin-bottom: 24px;
    }

    .glass-hero::before{
        content:"";
        position:absolute;
        inset:0;
        background:
            radial-gradient(circle at 80% 10%, rgba(255,255,255,.16), transparent 18%),
            radial-gradient(circle at 10% 90%, rgba(255,255,255,.10), transparent 20%);
        pointer-events:none;
    }

    .hero-badge{
        display:inline-flex;
        align-items:center;
        gap:8px;
        padding:10px 14px;
        border-radius:999px;
        background: rgba(255,255,255,.12);
        backdrop-filter: blur(10px);
        font-size:.9rem;
        font-weight:700;
        border: 1px solid rgba(255,255,255,.12);
        max-width: 100%;
        flex-wrap: wrap;
    }

    .hero-title{
        font-size: clamp(1.6rem, 3vw, 2.5rem);
        font-weight: 800;
        margin: 16px 0 10px;
        line-height: 1.4;
        word-break: break-word;
    }

    .hero-subtitle{
        color: rgba(255,255,255,.82);
        font-size: 1rem;
        line-height: 1.9;
        margin-bottom: 18px;
    }

    .hero-stats{
        display:grid;
        grid-template-columns: repeat(4, 1fr);
        gap:12px;
        margin-top: 18px;
    }

    .hero-stat{
        background: rgba(255,255,255,.09);
        border:1px solid rgba(255,255,255,.12);
        border-radius: 18px;
        padding: 14px;
        backdrop-filter: blur(8px);
        min-width: 0;
    }

    .hero-stat .label{
        display:block;
        font-size:.82rem;
        color: rgba(255,255,255,.72);
        margin-bottom:6px;
    }

    .hero-stat .value{
        font-size:1.02rem;
        font-weight:800;
        color:#fff;
        line-height: 1.6;
        word-break: break-word;
    }

    .price-value{
        display:flex;
        align-items:center;
        gap:6px;
        flex-wrap:wrap;
    }

    .price-value img{
        width:16px;
        height:16px;
        flex-shrink: 0;
    }

    .estate-grid{
        display:grid;
        grid-template-columns: minmax(0, 1.55fr) minmax(320px, .75fr);
        gap: 24px;
        align-items:start;
    }

    .cardx{
        background: var(--card);
        border:1px solid var(--line);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        overflow:hidden;
    }

    .cardx-head{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        padding:20px 22px 0;
    }

    .cardx-title{
        font-size:1.08rem;
        font-weight:800;
        margin:0;
        color:#0f172a;
    }

    .cardx-subtitle{
        color:var(--muted);
        font-size:.92rem;
        margin-top:4px;
    }

    .media-layout{
        padding: 20px 22px 22px;
    }

    .media-tabs{
        display:flex;
        flex-wrap:wrap;
        gap:10px;
        margin-bottom:16px;
    }

    .media-tab{
        border:none;
        background:#eef4ff;
        color:#1d4ed8;
        padding:12px 16px;
        border-radius: 999px;
        font-weight:800;
        font-size:.92rem;
        transition:.2s ease;
    }

    .media-tab.active,
    .media-tab:hover{
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color:#fff;
        box-shadow: 0 10px 24px rgba(15,91,215,.22);
    }

    .gallery-stage{
        display:grid;
        grid-template-columns: 1fr 126px;
        gap:14px;
        align-items:stretch;
    }

    .main-preview{
        position:relative;
        min-height: 560px;
        border-radius: 24px;
        overflow:hidden;
        background: #0f172a;
        box-shadow: var(--shadow-sm);
    }

    .main-preview img,
    .main-preview video,
    .main-preview iframe{
        width:100%;
        height:100%;
        object-fit:cover;
        display:block;
        border:none;
    }

    .preview-overlay{
        position:absolute;
        inset:auto 0 0 0;
        padding:20px;
        background: linear-gradient(to top, rgba(0,0,0,.65), rgba(0,0,0,0));
        color:#fff;
        pointer-events:none;
    }

    .preview-overlay .title{
        font-size:1.08rem;
        font-weight:800;
        margin-bottom:4px;
    }

    .preview-overlay .meta{
        color:rgba(255,255,255,.8);
        font-size:.9rem;
    }

    .media-rail{
        display:flex;
        flex-direction:column;
        gap:12px;
        max-height:560px;
        overflow:auto;
        padding-inline-end:2px;
    }

    .rail-item{
        position:relative;
        height:96px;
        border:none;
        border-radius: 18px;
        overflow:hidden;
        background:#e5e7eb;
        cursor:pointer;
        transition:.2s ease;
        outline:none;
        border:2px solid transparent;
        flex-shrink: 0;
    }

    .rail-item img,
    .rail-item video{
        width:100%;
        height:100%;
        object-fit:cover;
        display:block;
    }

    .rail-item::after{
        content:"";
        position:absolute;
        inset:0;
        background: linear-gradient(to top, rgba(0,0,0,.22), transparent);
    }

    .rail-item.active{
        border-color: var(--primary);
        transform: translateY(-1px);
        box-shadow: 0 8px 24px rgba(15,91,215,.18);
    }

    .rail-badge{
        position:absolute;
        bottom:8px;
        right:8px;
        z-index:2;
        background: rgba(255,255,255,.92);
        color:#111827;
        border-radius:999px;
        padding:4px 8px;
        font-size:.74rem;
        font-weight:800;
    }

    .floating-actions{
        position:absolute;
        top:18px;
        left:18px;
        z-index:3;
        display:flex;
        gap:10px;
        flex-wrap: wrap;
        max-width: calc(100% - 36px);
    }

    .fab-btn{
        width:48px;
        height:48px;
        border:none;
        border-radius:50%;
        display:flex;
        align-items:center;
        justify-content:center;
        background: rgba(255,255,255,.16);
        color:#fff;
        backdrop-filter: blur(14px);
        box-shadow: 0 10px 24px rgba(0,0,0,.15);
        transition:.2s ease;
        flex-shrink: 0;
    }

    .fab-btn:hover{
        transform: translateY(-2px);
        background: rgba(255,255,255,.24);
        color:#fff;
    }

    .thumb-counter{
        position:absolute;
        top:18px;
        right:18px;
        z-index:3;
        background: rgba(0,0,0,.44);
        color:#fff;
        border-radius:999px;
        padding:10px 14px;
        font-weight:800;
        font-size:.88rem;
        backdrop-filter: blur(8px);
        max-width: calc(100% - 36px);
    }

    .section-body{
        padding: 20px 22px 22px;
    }

    .quick-actions{
        display:grid;
        grid-template-columns: repeat(4, 1fr);
        gap:12px;
    }

    .quick-action{
        border:none;
        border-radius: 18px;
        padding:16px 14px;
        background: linear-gradient(180deg, #ffffff, #f8fbff);
        border:1px solid #dbe7ff;
        text-align:center;
        font-weight:800;
        color:#0f172a;
        box-shadow: 0 8px 22px rgba(2,132,199,.06);
        transition:.2s ease;
    }

    .quick-action i{
        display:block;
        font-size:1.2rem;
        margin-bottom:10px;
        color:var(--primary);
    }

    .quick-action:hover{
        transform:translateY(-3px);
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color:#fff;
    }

    .quick-action:hover i{
        color:#fff;
    }

.chip{
    display:inline-flex;
    align-items:center;
    gap:8px;
    padding:10px 16px;
    border-radius: 999px;
    background: linear-gradient(135deg, #ffffff, #f1f5f9);
    border:1px solid #e2e8f0;
    font-size:.9rem;
    font-weight:700;
    color:#0f172a;
    box-shadow: 0 6px 16px rgba(15,23,42,.06);
    transition:.2s ease;
}

.chip i{
    font-size:.9rem;
    color: var(--primary);
}

.chip:hover{
    transform: translateY(-2px);
    background: linear-gradient(135deg, var(--primary), var(--primary-2));
    color:#fff;
}

.chip:hover i{
    color:#fff;
}

    .detail-grid{
        display:grid;
        grid-template-columns: repeat(2, 1fr);
        gap:14px;
    }

    .detail-item{
        background: linear-gradient(180deg, #ffffff, #fafcff);
        border:1px solid var(--line);
        border-radius: 18px;
        padding:16px;
        min-height:92px;
        min-width: 0;
    }

    .detail-item .k{
        display:block;
        color: var(--muted);
        font-size:.86rem;
        margin-bottom:8px;
    }

    .detail-item .v{
        font-weight:800;
        font-size:1rem;
        color:#111827;
        line-height:1.7;
        word-break: break-word;
    }

    .description-box{
        background: linear-gradient(180deg, #ffffff, #fafcff);
        border:1px solid var(--line);
        border-radius: 20px;
        padding:18px;
        line-height:2;
        color:#334155;
        white-space:pre-line;
        word-break: break-word;
    }

    .map-shell{
        border-radius: 24px;
        overflow:hidden;
        border:1px solid var(--line);
        background:#fff;
    }

    .nearby-toolbar{
        display:flex;
        gap:10px;
        flex-wrap:wrap;
        padding: 0 22px 18px;
    }

    .nearby-btn{
        border:none;
        border-radius:999px;
        background:#eef4ff;
        color:#1d4ed8;
        padding:12px 16px;
        font-weight:800;
        transition:.2s ease;
    }

    .nearby-btn.active,
    .nearby-btn:hover{
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color:#fff;
        box-shadow: 0 10px 24px rgba(15,91,215,.22);
    }

    #map{
        height: 430px;
        width:100%;
    }

    .sticky-side{
        position: sticky;
        top: 18px;
        display:grid;
        gap:20px;
    }

    .seller-card{
        background:
            radial-gradient(circle at top left, rgba(15,91,215,.10), transparent 22%),
            #fff;
        border:1px solid var(--line);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        overflow:hidden;
    }

    .seller-cover{
        height:88px;
        background: linear-gradient(135deg, #0f5bd7, #114b89);
    }

    .seller-body{
        padding:0 20px 22px;
        margin-top:-36px;
    }

    .seller-avatar{
        width:84px;
        height:84px;
        border-radius:50%;
        object-fit:cover;
        border:4px solid #fff;
        box-shadow: var(--shadow-sm);
        background:#fff;
    }

    .seller-name{
        font-size:1.08rem;
        font-weight:800;
        margin:14px 0 4px;
        word-break: break-word;
    }

    .seller-phone{
        color:var(--muted);
        margin-bottom:16px;
        word-break: break-word;
    }

    .seller-metrics{
        display:grid;
        grid-template-columns: repeat(2, 1fr);
        gap:12px;
        margin-bottom:16px;
    }

    .seller-metric{
        background:#f8fafc;
        border:1px solid var(--line);
        border-radius:18px;
        padding:14px 12px;
        text-align:center;
        min-width: 0;
    }

    .seller-metric .k{
        display:block;
        color:var(--muted);
        font-size:.8rem;
        margin-bottom:6px;
    }

    .seller-metric .v{
        font-weight:800;
        color: var(--primary);
        word-break: break-word;
    }

    .cta-stack{
        display:grid;
        gap:10px;
    }

    .cta-primary,
    .cta-secondary{
        border:none;
        text-decoration:none;
        border-radius: 18px;
        padding:14px 16px;
        font-weight:800;
        text-align:center;
        display:flex;
        align-items:center;
        justify-content:center;
        gap:10px;
        transition:.2s ease;
    }

    .cta-primary{
        background: linear-gradient(135deg, var(--primary), var(--primary-2));
        color:#fff;
        box-shadow: 0 12px 28px rgba(15,91,215,.20);
    }

    .cta-primary:hover{
        color:#fff;
        transform: translateY(-2px);
    }

    .cta-secondary{
        background:#fff;
        color:#0f172a;
        border:1px solid var(--line);
    }

    .cta-secondary:hover{
        background:#f8fafc;
        color:#0f172a;
    }

    .social-row{
        display:flex;
        justify-content:center;
        gap:10px;
        flex-wrap:wrap;
        margin-top:16px;
    }

    .social-row a{
        width:42px;
        height:42px;
        display:flex;
        align-items:center;
        justify-content:center;
        border-radius:50%;
        background:#f8fafc;
        border:1px solid var(--line);
    }

    .social-row img{
        width:22px;
        height:22px;
        object-fit:contain;
    }

    .side-mini-card{
        background:#fff;
        border:1px solid var(--line);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-md);
        padding:18px;
    }

    .mini-stat{
        display:flex;
        align-items:center;
        gap:12px;
        padding:14px;
        border-radius:18px;
        background:#f8fafc;
        border:1px solid var(--line);
    }

    .mini-stat + .mini-stat{
        margin-top:12px;
    }

    .mini-stat img{
        width:24px;
        height:24px;
    }

    .offer-card{
        position:relative;
        border:1px solid var(--line);
        border-radius:24px;
        overflow:hidden;
        background:#fff;
        box-shadow: var(--shadow-sm);
    }

    .offer-card + .offer-card{
        margin-top:14px;
    }

    .offer-ribbon{
        position:absolute;
        top:14px;
        right:14px;
        background: linear-gradient(135deg, #ef4444, #f97316);
        color:#fff;
        border-radius:999px;
        padding:8px 10px;
        font-size:.78rem;
        font-weight:800;
        z-index:2;
    }

    .offer-inner{
        display:grid;
        grid-template-columns: 110px 1fr;
        gap:14px;
        padding:14px;
        align-items:center;
    }

    .offer-thumb{
        width:110px;
        height:110px;
        border-radius:18px;
        object-fit:cover;
        background:#e5e7eb;
    }

    .offer-name{
        font-weight:800;
        margin-bottom:6px;
        color:#111827;
        word-break: break-word;
    }

    .offer-price{
        font-weight:900;
        color: var(--primary);
        margin-bottom:4px;
        word-break: break-word;
    }

    .offer-expiry{
        color:var(--muted);
        font-size:.88rem;
        word-break: break-word;
    }

    .offer-links{
        display:flex;
        gap:12px;
        margin-top:10px;
    }

    .offer-links a{
        color:#0f172a;
        font-size:1.1rem;
    }

    .custom-modal .modal-content{
        border:none;
        border-radius: 28px;
        overflow:hidden;
        box-shadow: var(--shadow-lg);
    }

    .custom-modal .modal-header{
        background: linear-gradient(135deg, #0f5bd7, #114b89);
        color:#fff;
        border:none;
        padding:16px 20px;
    }

    .custom-modal .btn-close{
        filter: invert(1);
    }

    .fullscreen-gallery{
        display:grid;
        grid-template-columns: repeat(3, 1fr);
        gap:14px;
    }

    .fullscreen-gallery img{
        width:100%;
        height:240px;
        object-fit:cover;
        border-radius:18px;
    }

    .mobile-bar{
        position:fixed;
        bottom:12px;
        left:12px;
        right:12px;
        z-index:999;
        background: rgba(255,255,255,.9);
        backdrop-filter: blur(16px);
        border:1px solid rgba(255,255,255,.7);
        box-shadow: var(--shadow-lg);
        border-radius: 24px;
        padding:10px;
        display:none;
    }

    .mobile-bar-grid{
        display:grid;
        grid-template-columns:repeat(3,1fr);
        gap:10px;
    }

    .mobile-bar-grid a,
    .mobile-bar-grid button{
        border:none;
        background:#f8fafc;
        border-radius:18px;
        padding:12px;
        font-weight:800;
        color:var(--primary);
        font-size: .9rem;
    }

    .empty-media{
        min-height:420px;
        display:flex;
        align-items:center;
        justify-content:center;
        flex-direction:column;
        gap:12px;
        color:#94a3b8;
        background:linear-gradient(180deg, #f8fafc, #eef2f7);
        border-radius:24px;
        border:1px dashed #cbd5e1;
        padding: 20px;
        text-align: center;
    }

    @media (max-width: 1200px){
        .hero-stats{
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 992px){
        .estate-grid{
            grid-template-columns: 1fr;
        }

        .sticky-side{
            position:static;
        }

        .gallery-stage{
            grid-template-columns: 1fr;
        }

        .media-rail{
            flex-direction:row;
            max-height:none;
            overflow:auto;
        }

        .rail-item{
            min-width:110px;
            width:110px;
            height:88px;
        }

        .main-preview{
            min-height:420px;
        }

        .quick-actions{
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px){
        .estate-shell{
            padding-bottom:110px;
        }

        .glass-hero{
            padding:14px;
            border-radius:18px;
        }

        .hero-title{
            font-size:1.25rem;
            line-height:1.6;
            margin:12px 0 8px;
        }

        .hero-subtitle{
            font-size:.92rem;
            line-height:1.8;
            margin-bottom:14px;
        }

        .hero-badge{
            font-size:.78rem;
            padding:8px 12px;
        }

        .chips{
            gap:8px;
        }

        .chip{
            font-size:.82rem;
            padding:8px 10px;
        }

        .hero-stats{
            grid-template-columns: 1fr 1fr;
            gap:10px;
            margin-top:14px;
        }

        .hero-stat{
            padding:12px;
            border-radius:14px;
        }

        .hero-stat .label{
            font-size:.75rem;
            margin-bottom:4px;
        }

        .hero-stat .value{
            font-size:.95rem;
            display:flex;
            align-items:center;
            gap:6px;
            flex-wrap:wrap;
            line-height:1.5;
        }

        .hero-stat .value img,
        .price-value img{
            width:14px !important;
            height:14px !important;
            flex-shrink:0;
        }

        .cardx-head{
            padding:16px 16px 0;
        }

        .section-body,
        .media-layout{
            padding:16px;
        }

        .cardx-title{
            font-size:1rem;
        }

        .cardx-subtitle{
            font-size:.84rem;
        }

        .main-preview{
            min-height:240px;
            border-radius:16px;
        }

        .floating-actions{
            top:10px;
            left:10px;
            gap:8px;
            max-width: calc(100% - 20px);
        }

        .fab-btn{
            width:38px;
            height:38px;
            font-size:.9rem;
        }

        .thumb-counter{
            top:10px;
            right:10px;
            padding:6px 10px;
            font-size:.75rem;
            max-width: calc(100% - 20px);
        }

        .preview-overlay{
            padding:12px;
        }

        .preview-overlay .title{
            font-size:.92rem;
        }

        .preview-overlay .meta{
            font-size:.78rem;
        }

        .media-tab,
        .nearby-btn{
            padding:10px 12px;
            font-size:.82rem;
        }

        .detail-grid{
            grid-template-columns: 1fr;
        }

        .offer-inner{
            grid-template-columns: 1fr;
        }

        .offer-thumb{
            width:100%;
            height:180px;
        }

        .fullscreen-gallery{
            grid-template-columns: repeat(2, 1fr);
        }

        .mobile-bar{
            display:block;
        }

        .seller-body{
            padding:0 16px 18px;
        }

        .seller-metrics{
            grid-template-columns: 1fr 1fr;
            gap:10px;
        }

        #map{
            height: 320px;
        }
    }

  @media (max-width: 576px){

    .hero-stats{
        grid-template-columns: 1fr 1fr; /* صفين */
        gap:8px;
    }

    /* خلي السعر ياخذ صف كامل */
    .hero-stat:first-child{
        grid-column: span 2;
        background:#ffffff;
        color:#0f172a;
        border:none;
    }

    .hero-stat:first-child .label{
        color:#64748b;
    }

    .hero-stat:first-child .value{
        font-size:1.1rem;
        color:#0f172a;
    }

    .hero-stat:first-child .value img{
        width:14px;
        height:14px;
    }

    .hero-stat{
        padding:10px;
        border-radius:12px;
    }

    .hero-stat .label{
        font-size:.7rem;
    }

    .hero-stat .value{
        font-size:.85rem;
    }
}

        .hero-stat .value{
            font-size:.9rem;
        }

        .quick-actions{
            grid-template-columns: 1fr;
        }

        .fullscreen-gallery{
