        .mobile-bar-grid a,
        .mobile-bar-grid button{
            padding:10px;
            font-size:.82rem;
        }

        .seller-metrics{
            grid-template-columns: 1fr;
        }

        .main-preview{
            min-height:220px;
        }

        .empty-media{
            min-height:260px;
        }

        #map{
            height: 280px;
